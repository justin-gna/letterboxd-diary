{
  "name": "letterboxd-diary",
  "version": "1.0.0",
  "description": "A self-hosted Letterboxd diary widget for React. Displays recently watched films as a grid, list, or carousel via a Cloudflare Worker backend.",
  "keywords": [
    "letterboxd",
    "react",
    "widget",
    "diary",
    "cloudflare-workers"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^3.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "swr": "^2.4.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justin-gna/letterboxd-diary.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/justin-gna/letterboxd-diary/issues"
  },
  "homepage": "https://github.com/justin-gna/letterboxd-diary#readme"
}
